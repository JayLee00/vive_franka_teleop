# SteamVR udev rules for HTC Vive / Valve devices on Linux.
# Source: ValveSoftware/SteamVR-for-Linux, copied here so install is self-contained.
# Install: sudo cp 60-HTC-Vive-perms.rules /etc/udev/rules.d/  && sudo udevadm control --reload-rules && sudo udevadm trigger

# Valve Software (Watchman Dongle, Lighthouse, Tracker, Index, etc.)
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="28de", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="28de", MODE="0666"

# HTC Vive HMD
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0bb4", ATTRS{idProduct}=="2c87", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bb4", ATTRS{idProduct}=="2c87", MODE="0666"

# HTC Camera USB
SUBSYSTEM=="usb", ATTRS{idVendor}=="114d", ATTRS{idProduct}=="8328", MODE="0666"

# HTC Mass Storage
SUBSYSTEM=="usb", ATTRS{idVendor}=="114d", ATTRS{idProduct}=="8200", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="114d", ATTRS{idProduct}=="8a12", MODE="0666"
